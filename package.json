{
    "name": "ekalliptus-astro",
    "private": true,
    "type": "module",
    "packageManager": "bun@1.3.10",
    "scripts": {
        "dev": "astro dev",
        "build": "astro build && node -e \"const fs=require('fs'),path=require('path');const s='dist/server',c='dist/client';fs.copyFileSync(path.join(s,'entry.mjs'),path.join(c,'_worker.js'));fs.cpSync(path.join(s,'chunks'),path.join(c,'chunks'),{recursive:true});fs.copyFileSync(path.join(s,'virtual_astro_middleware.mjs'),path.join(c,'virtual_astro_middleware.mjs'));fs.rmSync('.wrangler/deploy',{recursive:true,force:true})\"",
        "preview": "astro preview",
        "astro": "astro",
        "migrate:blog": "bun run scripts/migrate-blog-to-supabase.ts"
    },
    "dependencies": {
        "@astrojs/cloudflare": "^13.2.1",
        "@astrojs/sitemap": "^3.7.2",
        "@fontsource/inter": "^5.2.8",
        "@supabase/supabase-js": "^2.99.2",
        "@tailwindcss/typography": "^0.5.19",
        "astro": "^6.1.9",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "i18next": "^25.8.18",
        "js-yaml": "^4.1.1",
        "lucide-astro": "^0.556.0",
        "marked": "^18.0.0",
        "tailwind-merge": "^3.5.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.8",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^22.16.5",
        "autoprefixer": "^10.4.27",
        "fast-check": "^4.7.0",
        "happy-dom": "^20.9.0",
        "postcss": "^8.5.8",
        "tailwindcss": "^3.4.0",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^5.8.3",
        "vitest": "^4.1.5"
    }
}
