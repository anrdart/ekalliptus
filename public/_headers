# Cloudflare Pages Security Headers & Configuration
# ekalliptus.id - Enhanced Trust & Safety
# Performance Optimization: Requirements 6.1, 8.4

# Security Headers - Applied to all routes (/*)
/*
  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff

  # Prevent clickjacking (XFO)
  X-Frame-Options: DENY

  # XSS Protection
  X-XSS-Protection: 1; mode=block

  # Referrer Policy
  Referrer-Policy: strict-origin-when-cross-origin

  # HSTS (HTTP Strict Transport Security) - Force HTTPS for 1 year
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Cross-Origin Opener Policy (COOP) - Prevent cross-origin attacks
  Cross-Origin-Opener-Policy: same-origin

  # Content Security Policy (CSP) - Prevent XSS attacks
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https://fonts.googleapis.com https://api.emailjs.com https://sheetdb.io https://static.cloudflareinsights.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://api.emailjs.com https://sheetdb.io https://lovable.dev https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://sheetdb.io; upgrade-insecure-requests

  # Permissions Policy - Restrict potentially dangerous APIs
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()

# HTML Cache Control - No caching for SPA (Requirements 6.1, 8.4)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Hashed Assets - Long-term caching with immutable (Requirements 6.1, 8.4)
# These files have content hashes in their names, so they can be cached forever
/_nuxt/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static Assets - 1 day caching (Requirements 6.1)
/*.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.jpg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.jpeg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.gif
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.svg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.ico
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.webp
  Cache-Control: public, max-age=31536000, immutable

# Font files - Long-term caching (Requirements 6.1)
/*.woff
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Vendor scripts - Long-term caching (Requirements 6.1)
/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# XML files (sitemap, etc.) - 1 day caching
/*.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=86400

# JSON files - Short caching
/*.json
  Cache-Control: public, max-age=3600

# Manifest file
/site.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=86400
