---
import Layout from '../../layouts/Layout.astro'
import Navigation from '../../components/Navigation.astro'
import VantaBackground from '../../components/VantaBackground.astro'
import PreLoader from '../../components/PreLoader.astro'
import ConsultationDialog from '../../components/ConsultationDialog.astro'
import { t, getLocaleFromRequest, getDir } from '../../i18n'
import { Check, ArrowRight, Shield, Zap, Bell, Clock } from 'lucide-astro'

export const prerender = false

const locale = getLocaleFromRequest(Astro.request)
const dir = getDir(locale)
const siteUrl = 'https://ekalliptus.com'
const canonical = new URL(Astro.url.pathname, siteUrl).toString()

const faqs = [
  { question: 'Apa saja yang dilakukan dalam maintenance website?', answer: 'Update core/plugin/theme, backup mingguan, monitoring keamanan dan uptime, optimasi performa, fix bug minor, technical support via WhatsApp/email.' },
  { question: 'Berapa kali backup dilakukan?', answer: 'Backup harian otomatis (incremental) + backup mingguan full. File backup tersimpan di cloud terpisah dengan retention 30 hari.' },
  { question: 'Apakah include penambahan content?', answer: 'Untuk paket Basic dan Standard tidak. Paket Premium include penambahan 5 halaman/post baru per bulan.' },
  { question: 'Bagaimana jika website saya hack?', answer: 'Kami handle restore dari backup, identifikasi root cause, patch keamanan, dan re-harden site. Termasuk dalam semua paket tanpa biaya tambahan.' },
  { question: 'Apakah bisa cancel kapan saja?', answer: 'Ya, paket bulanan tanpa kontrak jangka panjang. Cancel anytime dengan notice 7 hari.' },
  { question: 'Maintenance untuk website non-WordPress?', answer: 'Tentu — kami support custom website (Astro, Next.js, Laravel), hosting management, dan database maintenance.' }
]

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Jasa Maintenance Website Bulanan',
  serviceType: 'Website Maintenance',
  description: 'Jasa maintenance website bulanan: update, backup berkala, monitoring keamanan, dan technical support untuk WordPress, custom site, dan e-commerce.',
  provider: { '@id': `${siteUrl}#organization` },
  areaServed: [{ '@type': 'Country', name: 'Indonesia' }, { '@type': 'City', name: 'Tegal' }],
  offers: { '@type': 'AggregateOffer', priceCurrency: 'IDR', lowPrice: '500000', highPrice: '2000000', availability: 'https://schema.org/InStock' },
  url: canonical
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } }))
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Layanan', item: `${siteUrl}/services/maintenance` },
    { '@type': 'ListItem', position: 3, name: 'Website Maintenance', item: canonical }
  ]
}
---

<Layout
  title="Jasa Maintenance Website Bulanan | Update, Backup, Monitoring - Ekalliptus"
  description="Jasa maintenance website bulanan: update, backup berkala, monitoring keamanan, technical support. Mulai Rp 500rb/bulan. Untuk WordPress, custom site, e-commerce."
  lang={locale}
  dir={dir}
  keywords="jasa maintenance website, pemeliharaan website bulanan, maintenance wordpress, update website, backup website, monitoring keamanan website"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <VantaBackground />
  <PreLoader />
  <Navigation t={(key: string) => t(key, locale)} currentLang={locale} />

  <main class="relative z-0 flex min-h-screen flex-col pt-14 sm:pt-16 md:pt-20">
    <div class="container mx-auto max-w-6xl px-4 py-8 sm:py-12">

      <nav class="text-sm mb-6" aria-label="Breadcrumb">
        <a href="/" class="text-muted-foreground hover:text-foreground">Home</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <span class="text-foreground">Jasa Maintenance Website</span>
      </nav>

      <header class="mb-12 text-center">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-foreground mb-4">Jasa Maintenance Website Bulanan</h1>
        <p class="article-intro text-base sm:text-lg text-muted-foreground max-w-3xl mx-auto leading-relaxed">
          <strong>Jasa maintenance website</strong> adalah layanan pemeliharaan rutin yang mencakup update sistem, backup berkala, monitoring keamanan, dan technical support. Ekalliptus Digital menyediakan paket <strong>maintenance bulanan untuk WordPress, custom website, dan e-commerce</strong> mulai dari <strong>Rp 500rb per bulan</strong>, mencegah downtime dan menjaga performa website Anda tetap optimal.
        </p>
      </header>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">Apa yang Anda Dapatkan</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
          <div class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20">
            <div class="rounded-full bg-primary/10 p-3 w-fit mb-4"><Shield class="h-5 w-5 text-primary" /></div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Security Monitoring</h3>
            <p class="text-sm text-muted-foreground">Scan malware harian, firewall aktif, dan proteksi brute force.</p>
          </div>
          <div class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20">
            <div class="rounded-full bg-primary/10 p-3 w-fit mb-4"><Bell class="h-5 w-5 text-primary" /></div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Uptime Monitoring</h3>
            <p class="text-sm text-muted-foreground">Alert real-time jika website down, response time dalam 30 menit.</p>
          </div>
          <div class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20">
            <div class="rounded-full bg-primary/10 p-3 w-fit mb-4"><Zap class="h-5 w-5 text-primary" /></div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Performance Opt.</h3>
            <p class="text-sm text-muted-foreground">Optimasi bulanan untuk Core Web Vitals dan loading speed.</p>
          </div>
          <div class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20">
            <div class="rounded-full bg-primary/10 p-3 w-fit mb-4"><Clock class="h-5 w-5 text-primary" /></div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Backup Rutin</h3>
            <p class="text-sm text-muted-foreground">Backup harian otomatis ke cloud dengan retention 30 hari.</p>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">Paket & Harga Maintenance</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="glass-panel rounded-2xl p-6 bg-card/10 border border-border/20">
            <h3 class="text-xl font-bold text-foreground mb-2">Basic</h3>
            <p class="text-2xl font-bold text-primary mb-1">Rp 500rb</p>
            <p class="text-xs text-muted-foreground mb-4">/bulan</p>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Update core & plugins</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Backup mingguan</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Monitoring uptime</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Support via email</li>
            </ul>
          </div>
          <div class="glass-panel neon-border rounded-2xl p-6 bg-card/10">
            <h3 class="text-xl font-bold text-foreground mb-2">Standard</h3>
            <p class="text-2xl font-bold text-primary mb-1">Rp 1jt</p>
            <p class="text-xs text-muted-foreground mb-4">/bulan</p>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Semua paket Basic</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Backup harian</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Security scan harian</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Support WhatsApp</li>
            </ul>
          </div>
          <div class="glass-panel rounded-2xl p-6 bg-card/10 border border-border/20">
            <h3 class="text-xl font-bold text-foreground mb-2">Premium</h3>
            <p class="text-2xl font-bold text-primary mb-1">Rp 2jt</p>
            <p class="text-xs text-muted-foreground mb-4">/bulan</p>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Semua paket Standard</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> 5 halaman content/bulan</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Performance optimization</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Priority response 2 jam</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">Tools yang Kami Gunakan</h2>
        <div class="glass-panel rounded-2xl p-6 bg-card/10 border border-border/20 text-center">
          <div class="flex flex-wrap gap-2 justify-center">
            {['UpdraftPlus', 'Wordfence', 'Sucuri', 'Cloudflare', 'UptimeRobot', 'GTmetrix', 'Google Search Console', 'New Relic'].map(tech => (
              <span class="rounded-full bg-primary/10 px-4 py-1.5 text-xs font-medium text-primary">{tech}</span>
            ))}
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">Proses Kerja</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          {[
            { num: 1, title: 'Onboarding', desc: 'Akses credentials, audit kondisi website, setup monitoring' },
            { num: 2, title: 'Maintenance Rutin', desc: 'Update, backup, scan keamanan sesuai jadwal paket' },
            { num: 3, title: 'Monthly Report', desc: 'Laporan bulanan: uptime, performance, security status' },
            { num: 4, title: 'On-demand Support', desc: 'Respon cepat untuk isu darurat via WhatsApp/email' }
          ].map(step => (
            <div class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20 text-center">
              <div class="rounded-full bg-primary text-primary-foreground w-10 h-10 flex items-center justify-center font-bold mx-auto mb-3">{step.num}</div>
              <h3 class="font-semibold text-foreground mb-2">{step.title}</h3>
              <p class="text-sm text-muted-foreground">{step.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">FAQ</h2>
        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20 group">
              <summary class="font-semibold text-foreground cursor-pointer flex items-center justify-between">
                {faq.question}
                <span class="text-primary group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-sm text-muted-foreground mt-3">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">Artikel Terkait</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a href="/blog/website-maintenance-rutin" class="glass-panel rounded-2xl p-6 bg-card/10 border border-border/20 hover:border-primary/30 transition group">
            <h3 class="font-semibold text-foreground mb-2 group-hover:text-primary transition">5 Tanda Website Anda Butuh Redesign & Maintenance Rutin</h3>
            <p class="text-sm text-muted-foreground">Kenali tanda website perlu perhatian sebelum terlambat →</p>
          </a>
          <a href="/blog/tips-optimasi-website-seo-untuk-umkm" class="glass-panel rounded-2xl p-6 bg-card/10 border border-border/20 hover:border-primary/30 transition group">
            <h3 class="font-semibold text-foreground mb-2 group-hover:text-primary transition">10 Tips Optimasi Website SEO untuk UMKM Indonesia</h3>
            <p class="text-sm text-muted-foreground">Panduan SEO praktis untuk bisnis Anda →</p>
          </a>
        </div>
      </section>

      <section class="mb-12 text-center">
        <div class="glass-panel neon-border rounded-2xl sm:rounded-3xl p-8 bg-card/5">
          <h2 class="text-2xl sm:text-3xl font-bold text-foreground mb-3">Mulai Maintenance Website Anda</h2>
          <p class="text-muted-foreground mb-6">Jangan tunggu website bermasalah — mulai maintenance rutin sekarang.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/order" data-track="order" class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90">
              Order Sekarang <ArrowRight class="h-4 w-4" />
            </a>
            <a href="https://wa.me/6281999900306" target="_blank" rel="noopener" data-track="whatsapp" class="inline-flex items-center justify-center gap-2 rounded-full border border-border px-6 py-3 text-sm font-semibold text-foreground transition hover:bg-card/30">
              WhatsApp Konsultasi
            </a>
          </div>
        </div>
      </section>

    </div>
    <ConsultationDialog t={(key: string) => t(key, locale)} />
  </main>
</Layout>
