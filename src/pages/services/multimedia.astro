---
import Layout from '../../layouts/Layout.astro'
import Navigation from '../../components/Navigation.astro'
import VantaBackground from '../../components/VantaBackground.astro'
import PreLoader from '../../components/PreLoader.astro'
import ConsultationDialog from '../../components/ConsultationDialog.astro'
import { t, getLocaleFromRequest, getDir } from '../../i18n'
import { Check, ArrowRight, Play, Image, Zap, Shield } from 'lucide-astro'

export const prerender = false

const locale = getLocaleFromRequest(Astro.request)
const dir = getDir(locale)
const siteUrl = 'https://ekalliptus.com'
const canonical = new URL(Astro.url.pathname, siteUrl).toString()

const faqs = [
  { question: 'Berapa biaya editing video TikTok/Reels?', answer: 'Mulai Rp 50rb per video (durasi <60 detik). Paket bulanan 10 video Rp 450rb (hemat 10%). Custom effect dan motion graphics ada extra fee.' },
  { question: 'Berapa lama proses editing?', answer: 'Single video 1-2 hari kerja, paket bulanan delivery 2x seminggu, urgent (24 jam) ada surcharge 50%.' },
  { question: 'Format file apa yang disupport?', answer: 'Input: MP4, MOV, AVI, JPG, PNG, RAW. Output: MP4 (1080p/4K), JPG/PNG sesuai kebutuhan platform.' },
  { question: 'Apakah include musik dan SFX?', answer: 'Ya, royalty-free music dari Epidemic Sound dan SFX. Untuk musik branded/copyright butuh lisensi terpisah.' },
  { question: 'Bisa request style editing tertentu?', answer: 'Tentu — kami bisa match style dengan referensi yang Anda berikan, atau buat style guide untuk konsistensi konten.' },
  { question: 'Apakah termasuk editing foto produk?', answer: 'Ya, kami juga menyediakan editing foto produk: background removal, color correction, dan retouching mulai Rp 25rb/foto.' }
]

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Jasa Editing Foto & Video Profesional',
  serviceType: 'Photo & Video Editing',
  description: 'Jasa editing foto dan video profesional untuk konten TikTok, Instagram Reels, YouTube Shorts, dan foto produk e-commerce di Indonesia.',
  provider: { '@id': `${siteUrl}#organization` },
  areaServed: [{ '@type': 'Country', name: 'Indonesia' }, { '@type': 'City', name: 'Tegal' }],
  offers: { '@type': 'AggregateOffer', priceCurrency: 'IDR', lowPrice: '25000', highPrice: '5000000', availability: 'https://schema.org/InStock' },
  url: canonical
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } }))
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Layanan', item: `${siteUrl}/services/multimedia` },
    { '@type': 'ListItem', position: 3, name: 'Photo & Video Editing', item: canonical }
  ]
}
---

<Layout
  title="Jasa Editing Foto & Video Profesional | TikTok, Reels - Ekalliptus"
  description="Jasa editing foto produk dan video profesional untuk konten TikTok, Instagram Reels, YouTube. Mulai Rp 50rb per video. Promo 10 video hemat 10%."
  lang={locale}
  dir={dir}
  keywords="jasa editing video profesional, editing video tiktok, jasa foto produk, editing instagram reels, jasa multimedia editing, content creator"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <VantaBackground />
  <PreLoader />
  <Navigation t={(key: string) => t(key, locale)} currentLang={locale} />

  <main class="relative z-0 flex min-h-screen flex-col pt-14 sm:pt-16 md:pt-20">
    <div class="container mx-auto max-w-6xl px-4 py-8 sm:py-12">

      <nav class="text-sm mb-6" aria-label="Breadcrumb">
        <a href="/" class="text-muted-foreground hover:text-foreground">Home</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <span class="text-foreground">Jasa Editing Foto & Video</span>
      </nav>

      <header class="mb-12 text-center">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-foreground mb-4">Jasa Editing Foto & Video Profesional</h1>
        <p class="article-intro text-base sm:text-lg text-muted-foreground max-w-3xl mx-auto leading-relaxed">
          <strong>Jasa editing foto dan video profesional</strong> adalah layanan editing konten multimedia untuk kebutuhan bisnis, social media, dan marketing. Ekalliptus Digital menyediakan jasa editing untuk konten <strong>TikTok, Instagram Reels, YouTube Shorts</strong>, dan foto produk e-commerce, dengan harga mulai <strong>Rp 50rb per video</strong> dan promo paket bulanan.
        </p>
      </header>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">Apa yang Anda Dapatkan</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
          <div class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20">
            <div class="rounded-full bg-primary/10 p-3 w-fit mb-4"><Play class="h-5 w-5 text-primary" /></div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Video Short-Form</h3>
            <p class="text-sm text-muted-foreground">Editing TikTok, Reels, YouTube Shorts yang engaging dan viral-ready.</p>
          </div>
          <div class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20">
            <div class="rounded-full bg-primary/10 p-3 w-fit mb-4"><Image class="h-5 w-5 text-primary" /></div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Foto Produk</h3>
            <p class="text-sm text-muted-foreground">Background removal, color grading, dan retouching untuk e-commerce.</p>
          </div>
          <div class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20">
            <div class="rounded-full bg-primary/10 p-3 w-fit mb-4"><Zap class="h-5 w-5 text-primary" /></div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Motion Graphics</h3>
            <p class="text-sm text-muted-foreground">Animasi teks, lower third, transisi custom yang profesional.</p>
          </div>
          <div class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20">
            <div class="rounded-full bg-primary/10 p-3 w-fit mb-4"><Shield class="h-5 w-5 text-primary" /></div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Royalty-Free Music</h3>
            <p class="text-sm text-muted-foreground">Musik bebas copyright dari Epidemic Sound untuk semua konten.</p>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">Paket & Harga Editing</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="glass-panel rounded-2xl p-6 bg-card/10 border border-border/20">
            <h3 class="text-xl font-bold text-foreground mb-2">Single Video</h3>
            <p class="text-2xl font-bold text-primary mb-4">Rp 50rb - 150rb</p>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Durasi hingga 60 detik</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Transisi & musik</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Caption & teks</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> 1-2 hari pengerjaan</li>
            </ul>
          </div>
          <div class="glass-panel neon-border rounded-2xl p-6 bg-card/10">
            <h3 class="text-xl font-bold text-foreground mb-2">Paket Bulanan</h3>
            <p class="text-2xl font-bold text-primary mb-4">Rp 450rb - 1,5jt</p>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> 10 video/bulan</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Hemat 10% vs satuan</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Motion graphics</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Delivery 2x seminggu</li>
            </ul>
          </div>
          <div class="glass-panel rounded-2xl p-6 bg-card/10 border border-border/20">
            <h3 class="text-xl font-bold text-foreground mb-2">Foto Produk</h3>
            <p class="text-2xl font-bold text-primary mb-4">Rp 25rb - 100rb/foto</p>
            <ul class="space-y-2 text-sm text-muted-foreground">
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Background removal</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Color correction</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Retouching & cleanup</li>
              <li class="flex gap-2"><Check class="h-4 w-4 text-primary flex-shrink-0" /> Format JPG/PNG/WebP</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">Software yang Kami Gunakan</h2>
        <div class="glass-panel rounded-2xl p-6 bg-card/10 border border-border/20 text-center">
          <div class="flex flex-wrap gap-2 justify-center">
            {['Adobe Premiere Pro', 'Final Cut Pro', 'DaVinci Resolve', 'After Effects', 'Photoshop', 'Lightroom', 'CapCut', 'Epidemic Sound'].map(tech => (
              <span class="rounded-full bg-primary/10 px-4 py-1.5 text-xs font-medium text-primary">{tech}</span>
            ))}
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">Proses Kerja</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          {[
            { num: 1, title: 'Brief', desc: 'Diskusi style, reference, dan kebutuhan konten' },
            { num: 2, title: 'Kirim Material', desc: 'Upload raw footage/foto via Google Drive atau WeTransfer' },
            { num: 3, title: 'Editing', desc: 'Proses editing 1-2 hari kerja dengan progress update' },
            { num: 4, title: 'Delivery', desc: 'File final dikirim via Google Drive, revisi 2x gratis' }
          ].map(step => (
            <div class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20 text-center">
              <div class="rounded-full bg-primary text-primary-foreground w-10 h-10 flex items-center justify-center font-bold mx-auto mb-3">{step.num}</div>
              <h3 class="font-semibold text-foreground mb-2">{step.title}</h3>
              <p class="text-sm text-muted-foreground">{step.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">FAQ</h2>
        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="glass-panel rounded-2xl p-5 bg-card/10 border border-border/20 group">
              <summary class="font-semibold text-foreground cursor-pointer flex items-center justify-between">
                {faq.question}
                <span class="text-primary group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="text-sm text-muted-foreground mt-3">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-6 text-center">Artikel Terkait</h2>
        <div class="grid grid-cols-1 md:grid-cols-1 gap-6">
          <a href="/blog/jasa-editing-video-konten-sosial" class="glass-panel rounded-2xl p-6 bg-card/10 border border-border/20 hover:border-primary/30 transition group">
            <h3 class="font-semibold text-foreground mb-2 group-hover:text-primary transition">Jasa Editing Video Konten TikTok & Instagram Reels - Harga & Review</h3>
            <p class="text-sm text-muted-foreground">Panduan memilih jasa editing video yang tepat untuk bisnis Anda →</p>
          </a>
        </div>
      </section>

      <section class="mb-12 text-center">
        <div class="glass-panel neon-border rounded-2xl sm:rounded-3xl p-8 bg-card/5">
          <h2 class="text-2xl sm:text-3xl font-bold text-foreground mb-3">Butuh Jasa Editing Video & Foto?</h2>
          <p class="text-muted-foreground mb-6">Konsultasi GRATIS — kirim referensi, dapatkan estimasi harga dalam 2 jam.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/order" data-track="order" class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90">
              Order Sekarang <ArrowRight class="h-4 w-4" />
            </a>
            <a href="https://wa.me/6281999900306" target="_blank" rel="noopener" data-track="whatsapp" class="inline-flex items-center justify-center gap-2 rounded-full border border-border px-6 py-3 text-sm font-semibold text-foreground transition hover:bg-card/30">
              WhatsApp Konsultasi
            </a>
          </div>
        </div>
      </section>

    </div>
    <ConsultationDialog t={(key: string) => t(key, locale)} />
  </main>
</Layout>
