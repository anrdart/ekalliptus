---
import AdminLayout from '../layout.astro'
import { MessageSquare, RefreshCw, Send } from 'lucide-astro'
---

<AdminLayout title="Consultations">
  <div class="grid grid-cols-1 lg:grid-cols-[360px,1fr] gap-6">
    <section class="glass-card rounded-2xl p-5 min-h-[520px]">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold">Conversations</h2>
          <p class="text-sm text-muted-foreground">Recent visitor handoffs</p>
        </div>
        <button
          id="refresh-consultations"
          class="h-9 w-9 rounded-xl glass-panel inline-flex items-center justify-center hover:bg-accent cursor-interactive"
          aria-label="Refresh consultations"
        >
          <RefreshCw class="h-4 w-4" />
        </button>
      </div>
      <div id="consultation-list" class="space-y-3"></div>
      <div id="consultation-empty" class="hidden py-16 text-center">
        <div class="mx-auto mb-4 h-14 w-14 rounded-full bg-accent/10 flex items-center justify-center">
          <MessageSquare class="h-7 w-7 text-muted-foreground" />
        </div>
        <p class="text-sm font-medium">No conversations yet</p>
        <p class="text-xs text-muted-foreground">Visitor handoffs will appear here.</p>
      </div>
    </section>

    <section class="glass-card rounded-2xl p-5 min-h-[520px] flex flex-col">
      <div id="thread-empty" class="flex flex-1 flex-col items-center justify-center text-center">
        <div class="mb-4 h-16 w-16 rounded-full bg-primary/10 flex items-center justify-center">
          <MessageSquare class="h-8 w-8 text-primary" />
        </div>
        <h2 class="text-lg font-semibold">Select a conversation</h2>
        <p class="text-sm text-muted-foreground">Read the thread and reply from this panel.</p>
      </div>

      <div id="thread-panel" class="hidden flex-1 flex-col min-h-0">
        <div class="border-b border-border pb-4 mb-4">
          <h2 id="thread-title" class="text-lg font-semibold"></h2>
          <p id="thread-meta" class="text-sm text-muted-foreground"></p>
        </div>

        <div id="message-list" class="flex-1 min-h-[320px] overflow-y-auto space-y-3 pr-1 custom-scrollbar"></div>

        <form id="reply-form" class="mt-4 flex gap-3 border-t border-border pt-4">
          <textarea
            id="reply-input"
            rows="2"
            class="glass-input flex-1 resize-none rounded-xl px-4 py-3 text-sm outline-none"
            placeholder="Write a reply..."
          ></textarea>
          <button
            type="submit"
            class="h-12 w-12 rounded-xl bg-primary text-primary-foreground inline-flex items-center justify-center hover:bg-primary/90 cursor-interactive"
            aria-label="Send reply"
          >
            <Send class="h-4 w-4" />
          </button>
        </form>
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  type ConsultationMessage = {
    id: string
    sender_type: 'visitor' | 'bot' | 'admin'
    sender_name: string | null
    content: string
    created_at: string
  }

  type Consultation = {
    id: string
    session_id: string | null
    visitor_name: string | null
    last_message: string | null
    last_message_at: string | null
    unread_count: number
    status: string
    messages: ConsultationMessage[]
  }

  const listEl = document.getElementById('consultation-list')
  const emptyEl = document.getElementById('consultation-empty')
  const refreshBtn = document.getElementById('refresh-consultations')
  const threadEmpty = document.getElementById('thread-empty')
  const threadPanel = document.getElementById('thread-panel')
  const threadTitle = document.getElementById('thread-title')
  const threadMeta = document.getElementById('thread-meta')
  const messageList = document.getElementById('message-list')
  const replyForm = document.getElementById('reply-form') as HTMLFormElement | null
  const replyInput = document.getElementById('reply-input') as HTMLTextAreaElement | null

  let consultations: Consultation[] = []
  let selectedId = ''

  function formatDate(date: string | null): string {
    if (!date) return 'No messages yet'
    return new Intl.DateTimeFormat('id-ID', {
      dateStyle: 'medium',
      timeStyle: 'short'
    }).format(new Date(date))
  }

  function createConsultationButton(consultation: Consultation): HTMLButtonElement {
    const button = document.createElement('button')
    button.type = 'button'
    button.className = 'w-full rounded-xl border border-border bg-card/50 p-3 text-left transition hover:bg-accent/40 cursor-interactive'
    if (consultation.id === selectedId) {
      button.classList.add('border-primary', 'bg-primary/10')
    }

    const title = document.createElement('div')
    title.className = 'flex items-center justify-between gap-3'

    const name = document.createElement('p')
    name.className = 'text-sm font-semibold truncate'
    name.textContent = consultation.visitor_name || 'Pengunjung'

    const badge = document.createElement('span')
    badge.className = 'rounded-full bg-primary/10 px-2 py-0.5 text-[11px] font-medium text-primary'
    badge.textContent = consultation.status

    title.appendChild(name)
    title.appendChild(badge)

    const message = document.createElement('p')
    message.className = 'mt-2 line-clamp-2 text-xs text-muted-foreground'
    message.textContent = consultation.last_message || 'No message preview'

    const date = document.createElement('p')
    date.className = 'mt-2 text-[11px] text-muted-foreground/70'
    date.textContent = formatDate(consultation.last_message_at)

    button.appendChild(title)
    button.appendChild(message)
    button.appendChild(date)
    button.addEventListener('click', () => {
      selectedId = consultation.id
      renderList()
      renderThread()
    })

    return button
  }

  function renderList() {
    if (!listEl || !emptyEl) return
    listEl.innerHTML = ''
    emptyEl.classList.toggle('hidden', consultations.length > 0)

    consultations.forEach((consultation) => {
      listEl.appendChild(createConsultationButton(consultation))
    })
  }

  function createMessageBubble(message: ConsultationMessage): HTMLDivElement {
    const wrapper = document.createElement('div')
    const isAdmin = message.sender_type === 'admin'
    wrapper.className = isAdmin ? 'flex justify-end' : 'flex justify-start'

    const bubble = document.createElement('div')
    bubble.className = isAdmin
      ? 'max-w-[80%] rounded-2xl rounded-tr-md bg-primary px-4 py-3 text-primary-foreground'
      : 'max-w-[80%] rounded-2xl rounded-tl-md border border-border bg-card px-4 py-3'

    const sender = document.createElement('p')
    sender.className = isAdmin ? 'mb-1 text-[11px] opacity-80' : 'mb-1 text-[11px] text-muted-foreground'
    sender.textContent = message.sender_name || message.sender_type

    const content = document.createElement('p')
    content.className = 'whitespace-pre-wrap text-sm leading-relaxed'
    content.textContent = message.content

    bubble.appendChild(sender)
    bubble.appendChild(content)
    wrapper.appendChild(bubble)
    return wrapper
  }

  function renderThread() {
    const selected = consultations.find((item) => item.id === selectedId)
    if (!selected || !threadEmpty || !threadPanel || !threadTitle || !threadMeta || !messageList) return

    threadEmpty.classList.add('hidden')
    threadPanel.classList.remove('hidden')
    threadPanel.classList.add('flex')
    threadTitle.textContent = selected.visitor_name || 'Pengunjung'
    threadMeta.textContent = `${selected.session_id || 'No session'} • ${formatDate(selected.last_message_at)}`

    messageList.innerHTML = ''
    selected.messages.forEach((message) => {
      messageList.appendChild(createMessageBubble(message))
    })
    messageList.scrollTop = messageList.scrollHeight
  }

  async function loadConsultations() {
    try {
      const response = await fetch('/api/admin/consultations')
      if (!response.ok) throw new Error('Failed to fetch consultations')
      const data = await response.json()
      consultations = data.consultations || []
      if (!selectedId && consultations.length > 0) {
        selectedId = consultations[0].id
      }
      renderList()
      if (selectedId) renderThread()
    } catch (error) {
      console.error(error)
      consultations = []
      renderList()
    }
  }

  refreshBtn?.addEventListener('click', loadConsultations)

  replyForm?.addEventListener('submit', async (event) => {
    event.preventDefault()
    if (!selectedId || !replyInput) return

    const content = replyInput.value.trim()
    if (!content) return

    const response = await fetch(`/api/admin/consultations/${selectedId}/messages`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content })
    })

    if (response.ok) {
      replyInput.value = ''
      await loadConsultations()
    }
  })

  loadConsultations()
</script>
