---
import AdminLayout from '../../layout.astro'
import { CreditCard, Settings, ToggleLeft, ToggleRight, Plus, Settings2 } from 'lucide-astro'
---

<AdminLayout title="Payment Gateways">
  <div class="mb-6">
    <h1 class="text-3xl font-bold mb-2">Payment Gateways</h1>
    <p class="text-muted-foreground">Manage payment gateway configurations and settings</p>
  </div>

  <!-- Gateways Grid -->
  <div id="gateways-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Gateway cards will be rendered here -->
  </div>

  <!-- Empty State -->
  <div id="empty-state" class="hidden glass-card rounded-2xl p-12 text-center">
    <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-accent/10 mb-4">
      <CreditCard class="h-8 w-8 text-muted-foreground" />
    </div>
    <h3 class="text-lg font-semibold mb-2">No payment gateways configured</h3>
    <p class="text-sm text-muted-foreground mb-4">Add a payment gateway to start accepting payments</p>
  </div>

  <!-- Loading State -->
  <div id="loading-state" class="glass-card rounded-2xl p-12 text-center">
    <div class="inline-flex h-8 w-8 animate-spin rounded-full border-4 border-primary border-t-transparent mb-4"></div>
    <p class="text-sm text-muted-foreground">Loading payment gateways...</p>
  </div>

  <!-- Configure Modal -->
  <div id="configure-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
    <div class="glass-card rounded-2xl p-6 max-w-md w-full max-h-[90vh] overflow-y-auto">
      <h2 id="modal-title" class="text-xl font-bold mb-4">Configure Gateway</h2>
      <div id="modal-content">
        <!-- Modal content will be rendered here -->
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .gateway-card {
    transition: all 0.2s ease;
  }

  .gateway-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 40px -10px hsl(var(--primary) / 0.2);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .status-badge.active {
    background: hsl(142 76% 36% / 0.15);
    color: hsl(142 76% 36%);
    border: 1px solid hsl(142 76% 36% / 0.3);
  }

  .status-badge.inactive {
    background: hsl(var(--muted) / 0.3);
    color: hsl(var(--muted-foreground));
    border: 1px solid hsl(var(--border));
  }

  .toggle-switch {
    position: relative;
    width: 48px;
    height: 24px;
    background: hsl(var(--muted) / 0.5);
    border-radius: 9999px;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .toggle-switch.active {
    background: hsl(var(--primary));
  }

  .toggle-switch::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 20px;
    height: 20px;
    background: white;
    border-radius: 9999px;
    transition: transform 0.2s ease;
  }

  .toggle-switch.active::after {
    transform: translateX(24px);
  }
</style>

<script>
  const gatewaysContainer = document.getElementById('gateways-container')
  const emptyState = document.getElementById('empty-state')
  const loadingState = document.getElementById('loading-state')
  const configureModal = document.getElementById('configure-modal')
  const modalTitle = document.getElementById('modal-title')
  const modalContent = document.getElementById('modal-content')

  let gateways = []

  async function fetchGateways() {
    try {
      const response = await fetch('/api/admin/gateways')
      if (response.ok) {
        const data = await response.json()
        gateways = data.gateways || []
        renderGateways()
      } else {
        console.error('Failed to fetch gateways')
        showError()
      }
    } catch (error) {
      console.error('Failed to fetch gateways:', error)
      showError()
    } finally {
      if (loadingState) {
        loadingState.classList.add('hidden')
      }
    }
  }

  function showError() {
    if (emptyState) {
      emptyState.classList.remove('hidden')
      const title = emptyState.querySelector('h3')
      const desc = emptyState.querySelector('p')
      if (title) title.textContent = 'Error loading gateways'
      if (desc) desc.textContent = 'Please refresh the page to try again'
    }
  }

  function renderGateways() {
    if (!gatewaysContainer) return

    gatewaysContainer.innerHTML = ''

    if (gateways.length === 0) {
      if (emptyState) emptyState.classList.remove('hidden')
      return
    }

    if (emptyState) emptyState.classList.add('hidden')

    gateways.forEach(gateway => {
      const card = createGatewayCard(gateway)
      gatewaysContainer.appendChild(card)
    })
  }

  function createGatewayCard(gateway) {
    const card = document.createElement('div')
    card.className = 'gateway-card glass-card rounded-2xl p-6'

    const isActive = gateway.is_active
    const statusText = isActive ? 'Active' : 'Inactive'
    const statusClass = isActive ? 'active' : 'inactive'

    // Create SVG icon
    const iconSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg')
    iconSvg.setAttribute('width', '20')
    iconSvg.setAttribute('height', '20')
    iconSvg.setAttribute('viewBox', '0 0 24 24')
    iconSvg.setAttribute('fill', 'none')
    iconSvg.setAttribute('stroke', 'currentColor')
    iconSvg.setAttribute('stroke-width', '2')
    iconSvg.setAttribute('stroke-linecap', 'round')
    iconSvg.setAttribute('stroke-linejoin', 'round')
    iconSvg.innerHTML = '<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>'

    const iconContainer = document.createElement('div')
    iconContainer.className = 'h-10 w-10 rounded-xl bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center'
    iconContainer.appendChild(iconSvg)

    const nameEl = document.createElement('h3')
    nameEl.className = 'font-semibold text-lg'
    nameEl.textContent = gateway.display_name || gateway.name

    const statusBadge = document.createElement('span')
    statusBadge.className = `status-badge ${statusClass}`
    statusBadge.textContent = statusText

    const nameContainer = document.createElement('div')
    nameContainer.appendChild(nameEl)
    nameContainer.appendChild(statusBadge)

    const headerLeft = document.createElement('div')
    headerLeft.className = 'flex items-center gap-3'
    headerLeft.appendChild(iconContainer)
    headerLeft.appendChild(nameContainer)

    const toggleSwitch = document.createElement('div')
    toggleSwitch.className = `toggle-switch ${isActive ? 'active' : ''}`
    toggleSwitch.dataset.gatewayId = gateway.id

    const header = document.createElement('div')
    header.className = 'flex items-start justify-between mb-4'
    header.appendChild(headerLeft)
    header.appendChild(toggleSwitch)

    // Details
    const detailsContainer = document.createElement('div')
    detailsContainer.className = 'space-y-2 mb-4'

    const details = [
      { label: 'Priority', value: (gateway.priority || 0).toString() },
      { label: 'Fee', value: `${gateway.fee_percent || 0}% + Rp${(gateway.fee_flat || 0).toLocaleString('id-ID')}` },
      { label: 'QR Support', value: gateway.supports_qr ? 'Yes' : 'No' }
    ]

    details.forEach(detail => {
      const row = document.createElement('div')
      row.className = 'flex justify-between text-sm'

      const label = document.createElement('span')
      label.className = 'text-muted-foreground'
      label.textContent = detail.label

      const value = document.createElement('span')
      value.className = 'font-medium'
      value.textContent = detail.value

      row.appendChild(label)
      row.appendChild(value)
      detailsContainer.appendChild(row)
    })

    // Configure button
    const buttonContainer = document.createElement('div')
    buttonContainer.className = 'flex gap-2'

    const configureBtn = document.createElement('button')
    configureBtn.className = 'configure-btn flex-1 inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium rounded-xl glass-panel hover:bg-accent cursor-pointer'
    configureBtn.dataset.gatewayId = gateway.id

    const settingsIcon = document.createElementNS('http://www.w3.org/2000/svg', 'svg')
    settingsIcon.setAttribute('width', '16')
    settingsIcon.setAttribute('height', '16')
    settingsIcon.setAttribute('viewBox', '0 0 24 24')
    settingsIcon.setAttribute('fill', 'none')
    settingsIcon.setAttribute('stroke', 'currentColor')
    settingsIcon.setAttribute('stroke-width', '2')
    settingsIcon.setAttribute('stroke-linecap', 'round')
    settingsIcon.setAttribute('stroke-linejoin', 'round')
    settingsIcon.innerHTML = '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>'

    const btnText = document.createTextNode(' Configure')
    configureBtn.appendChild(settingsIcon)
    configureBtn.appendChild(btnText)
    buttonContainer.appendChild(configureBtn)

    card.appendChild(header)
    card.appendChild(detailsContainer)
    card.appendChild(buttonContainer)

    // Event listeners
    toggleSwitch.addEventListener('click', () => toggleGateway(gateway.id, !gateway.is_active))
    configureBtn.addEventListener('click', () => openConfigureModal(gateway))

    return card
  }

  async function toggleGateway(gatewayId, newState) {
    try {
      const response = await fetch(`/api/admin/gateways/${gatewayId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ is_active: newState })
      })

      if (response.ok) {
        await fetchGateways()
      } else {
        console.error('Failed to toggle gateway')
      }
    } catch (error) {
      console.error('Failed to toggle gateway:', error)
    }
  }

  function openConfigureModal(gateway) {
    if (!configureModal || !modalTitle || !modalContent) return

    modalTitle.textContent = `Configure ${gateway.display_name || gateway.name}`

    // Create form using safe DOM methods
    const form = document.createElement('form')
    form.id = 'configure-form'
    form.className = 'space-y-4'

    // Display Name
    const displayNameDiv = createFormField('Display Name', 'text', 'display_name', gateway.display_name || gateway.name, true)
    form.appendChild(displayNameDiv)

    // Priority
    const priorityDiv = createFormField('Priority', 'number', 'priority', (gateway.priority || 0).toString(), true)
    form.appendChild(priorityDiv)

    // Fee Percentage
    const feePercentDiv = createFormField('Fee Percentage (%)', 'number', 'fee_percent', (gateway.fee_percent || 0).toString(), true, '0.01')
    form.appendChild(feePercentDiv)

    // Fee Flat
    const feeFlatDiv = createFormField('Fee Flat (Rp)', 'number', 'fee_flat', (gateway.fee_flat || 0).toString(), true)
    form.appendChild(feeFlatDiv)

    // Supports QR checkbox
    const checkboxDiv = document.createElement('div')
    checkboxDiv.className = 'flex items-center gap-2'

    const checkbox = document.createElement('input')
    checkbox.type = 'checkbox'
    checkbox.name = 'supports_qr'
    checkbox.id = 'supports_qr'
    checkbox.checked = gateway.supports_qr
    checkbox.className = 'rounded cursor-pointer'

    const checkboxLabel = document.createElement('label')
    checkboxLabel.htmlFor = 'supports_qr'
    checkboxLabel.className = 'text-sm cursor-pointer'
    checkboxLabel.textContent = 'Supports QR Payments'

    checkboxDiv.appendChild(checkbox)
    checkboxDiv.appendChild(checkboxLabel)
    form.appendChild(checkboxDiv)

    // Buttons
    const buttonContainer = document.createElement('div')
    buttonContainer.className = 'flex gap-2 pt-4'

    const submitBtn = document.createElement('button')
    submitBtn.type = 'submit'
    submitBtn.className = 'flex-1 inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium rounded-xl bg-primary text-primary-foreground hover:bg-primary/90 cursor-pointer'
    submitBtn.textContent = 'Save Changes'

    const cancelBtn = document.createElement('button')
    cancelBtn.type = 'button'
    cancelBtn.id = 'cancel-btn'
    cancelBtn.className = 'inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium rounded-xl glass-panel hover:bg-accent cursor-pointer'
    cancelBtn.textContent = 'Cancel'

    buttonContainer.appendChild(submitBtn)
    buttonContainer.appendChild(cancelBtn)
    form.appendChild(buttonContainer)

    modalContent.innerHTML = ''
    modalContent.appendChild(form)

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const formData = new FormData(form)
      const updates = {
        display_name: formData.get('display_name'),
        priority: parseInt(formData.get('priority')),
        fee_percent: parseFloat(formData.get('fee_percent')),
        fee_flat: parseInt(formData.get('fee_flat')),
        supports_qr: formData.get('supports_qr') === 'on'
      }

      try {
        const response = await fetch(`/api/admin/gateways/${gateway.id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updates)
        })

        if (response.ok) {
          closeModal()
          await fetchGateways()
        } else {
          console.error('Failed to update gateway')
        }
      } catch (error) {
        console.error('Failed to update gateway:', error)
      }
    })

    cancelBtn.addEventListener('click', closeModal)

    configureModal.classList.remove('hidden')
    configureModal.classList.add('flex')
  }

  function createFormField(label, type, name, value, required = false, step = null) {
    const div = document.createElement('div')

    const labelEl = document.createElement('label')
    labelEl.className = 'block text-sm font-medium mb-2'
    labelEl.textContent = label

    const input = document.createElement('input')
    input.type = type
    input.name = name
    input.value = value
    input.required = required
    input.className = 'glass-input w-full rounded-xl px-4 py-2.5 text-sm outline-none cursor-pointer'

    if (step) {
      input.step = step
    }

    div.appendChild(labelEl)
    div.appendChild(input)

    return div
  }

  function closeModal() {
    if (configureModal) {
      configureModal.classList.add('hidden')
      configureModal.classList.remove('flex')
    }
  }

  // Close modal on backdrop click
  if (configureModal) {
    configureModal.addEventListener('click', (e) => {
      if (e.target === configureModal) {
        closeModal()
      }
    })
  }

  // Initial fetch
  fetchGateways()
</script>
