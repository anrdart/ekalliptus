---
import { MessageCircle, Phone, Mail, Navigation, ArrowRight } from 'lucide-astro'

interface Props {
  t: (key: string) => string
}

const { t } = Astro.props
---

<section id="contact" class="content-vis relative px-4 py-24">
  <div class="relative z-10 mx-auto max-w-4xl">
    <div class="glass-panel neon-border rounded-2xl sm:rounded-3xl p-6 sm:p-8 md:p-12 text-center">
      <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 sm:px-5 py-2 text-[0.6rem] sm:text-[0.65rem] font-semibold uppercase tracking-[0.5em] sm:tracking-[0.6em] text-primary mb-4 sm:mb-6">
        <MessageCircle class="h-4 w-4" />
        <span>{t('contactCTA.title')}</span>
      </div>
      
      <h2 class="text-2xl sm:text-3xl font-semibold text-foreground md:text-4xl mb-4">
        {t('contactCTA.title')}
      </h2>
      
      <p class="text-muted-foreground mb-6 sm:mb-8 max-w-2xl mx-auto text-sm sm:text-base">
        {t('contactCTA.description')}
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 mb-8 sm:mb-10">
        <a
          href="https://wa.me/6281999900306"
          target="_blank"
          rel="noopener noreferrer"
          class="glass-panel rounded-2xl p-5 sm:p-6 hover:bg-card/30 transition-all cursor-interactive group active:scale-[0.99]"
        >
          <div class="h-11 w-11 sm:h-12 sm:w-12 rounded-xl bg-green-500/20 flex items-center justify-center mx-auto mb-3 sm:mb-4 group-hover:scale-110 transition-transform">
            <Phone class="h-5 w-5 sm:h-6 sm:w-6 text-green-500" />
          </div>
          <h3 class="font-semibold text-foreground mb-1 text-sm sm:text-base">WhatsApp</h3>
          <p class="text-xs sm:text-sm text-muted-foreground">{t('contactCTA.contact.phone')}</p>
        </a>

        <a
          href="mailto:ekalliptus@gmail.com"
          class="glass-panel rounded-2xl p-5 sm:p-6 hover:bg-card/30 transition-all cursor-interactive group active:scale-[0.99]"
        >
          <div class="h-11 w-11 sm:h-12 sm:w-12 rounded-xl bg-primary/20 flex items-center justify-center mx-auto mb-3 sm:mb-4 group-hover:scale-110 transition-transform">
            <Mail class="h-5 w-5 sm:h-6 sm:w-6 text-primary" />
          </div>
          <h3 class="font-semibold text-foreground mb-1 text-sm sm:text-base">Email</h3>
          <p class="text-xs sm:text-sm text-muted-foreground break-all">ekalliptus@gmail.com</p>
        </a>

        <div class="glass-panel rounded-2xl p-5 sm:p-6">
          <div class="h-11 w-11 sm:h-12 sm:w-12 rounded-xl bg-green-500/20 flex items-center justify-center mx-auto mb-3 sm:mb-4">
            <Navigation class="h-5 w-5 sm:h-6 sm:w-6 text-green-500" />
          </div>
          <h3 class="font-semibold text-foreground mb-1 text-sm sm:text-base">Lokasi</h3>
          <p class="text-xs sm:text-sm text-muted-foreground">Tegal, Indonesia</p>
        </div>
      </div>

      <a
        href="/order"
        class="group inline-flex items-center justify-center gap-3 rounded-full bg-primary px-8 sm:px-10 py-4 sm:py-5 text-base sm:text-lg font-semibold text-primary-foreground transition-all duration-300 hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/25 md:hover:scale-105 active:scale-[0.98] cursor-interactive min-h-[44px]"
      >
        {t('contactCTA.buttons.whatsapp')}
        <ArrowRight class="h-5 w-5 transition-transform group-hover:translate-x-1" />
      </a>

      <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-muted-foreground">
        Tersedia 24/7 untuk konsultasi
      </p>
    </div>
  </div>
</section>
