---
/**
 * SocialShare Component - Comprehensive social sharing buttons
 *
 * Platforms included:
 * - WhatsApp (Indonesia's most popular)
 * - Facebook
 * - Twitter/X
 * - LinkedIn
 * - Telegram
 * - Pinterest
 * - Email
 * - Copy Link
 */
interface Props {
  title: string
  url: string
  description?: string
  image?: string
  showLabels?: boolean
  className?: string
}

const {
  title,
  url,
  description = '',
  image,
  showLabels = true,
  className = ''
} = Astro.props

// URL encode functions
const encodedTitle = encodeURIComponent(title)
const encodedUrl = encodeURIComponent(url)
const encodedDescription = encodeURIComponent(description)
const encodedImage = image ? encodeURIComponent(image) : ''

// Platform configurations
const platforms = [
  {
    name: 'WhatsApp',
    id: 'whatsapp',
    color: '#25D366',
    icon: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.298-.149-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.298-.149-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.298-.149-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.298-.149-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.298-.149-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.298-.149-1.255-.463-2.39-1.475C7.326 7.1 5.5 8.5 5.5 10.5c0 2.5 1.5 4.5 3.5 5.5 1 0 2 1 2 2v2c3.5-1 6-4 7-7l1-1c1.5-1.5 2-3 2-5 0-2.5-1.5-4.5-3.5-5.5-1 0-2 1-2 2v1c-1.5 0-3-1-4-2l-1-1"/></svg>`,
    shareUrl: `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`,
    ariaLabel: 'Share to WhatsApp'
  },
  {
    name: 'Facebook',
    id: 'facebook',
    color: '#1877F2',
    icon: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.518c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
    shareUrl: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}&t=${encodedTitle}`,
    ariaLabel: 'Share to Facebook'
  },
  {
    name: 'X (Twitter)',
    id: 'twitter',
    color: '#000000',
    icon: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
    shareUrl: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}&via=ekalliptus`,
    ariaLabel: 'Share to X'
  },
  {
    name: 'LinkedIn',
    id: 'linkedin',
    color: '#0A66C2',
    icon: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
    shareUrl: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}&title=${encodedTitle}&summary=${encodedDescription}`,
    ariaLabel: 'Share to LinkedIn'
  },
  {
    name: 'Telegram',
    id: 'telegram',
    color: '#26A5E4',
    icon: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0-12-12zm6.658 8.56l-1.83 6.61-2.856-1.83-2.276 1.92-2.062-4.86-2.197 1.04-1.803 6.19 6.996 3.61z"/></svg>`,
    shareUrl: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
    ariaLabel: 'Share to Telegram'
  },
  {
    name: 'Pinterest',
    id: 'pinterest',
    color: '#E60023',
    icon: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-3.408.736-.332 1.467-.445 2.205-.278.706.16 1.256.567 1.256 1.158 0 .648-.437 1.487-1.168 2.344-.638.739-1.081 1.35-1.081 2.289 0 .827.575 1.544 1.375 1.862.75.296 1.625.27 2.258-.106.604-.348 1.033-.918 1.033-1.395 0-.689-.519-1.168-1.083-1.168-.581 0-1.083.479-1.083 1.168 0 .707.527 1.375 1.083 1.395-.633.376-1.508.404-2.258.106-.8-.318-1.375-1.035-1.375-1.862 0-.939.443-1.55 1.081-2.289.731-.857 1.168-1.696 1.168-2.344 0-.591-.55-1.398-1.256-1.58-.738-.167-1.469-.054-2.205.278-1.201.497-2.168 1.745-2.168 3.408 0 1.061.359 1.781.359 1.781s1.687 5.018 1.687 5.018c.248 1.036.146 2.49-.041 3.439-.417-.242-.83-.538-1.224-.886-.087.527-.148 1.063-.148 1.606 0 4.134 2.936 7.58 6.811 7.58 3.875 0 6.811-3.446 6.811-7.58 0-4.14-2.767-7.58-6.811-7.58z"/></svg>`,
    shareUrl: `https://pinterest.com/pin/create/button/?url=${encodedUrl}&media=${encodedImage}&description=${encodedTitle}`,
    ariaLabel: 'Share to Pinterest'
  },
  {
    name: 'Email',
    id: 'email',
    color: '#666666',
    icon: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    shareUrl: `mailto:?subject=${encodedTitle}&body=${encodedDescription}%0A%0A${encodedUrl}`,
    ariaLabel: 'Share via Email'
  }
]
---

<div class={`social-share ${className}`}>
  <span class="social-share-label text-sm font-medium text-muted-foreground mb-2 block">Bagikan:</span>

  <div class="flex flex-wrap gap-2">
    {platforms.map(platform => (
      <a
        href={platform.shareUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="social-share-button group relative inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-medium transition-all hover:scale-105"
        style={`--platform-color: ${platform.color}`}
        aria-label={platform.ariaLabel}
      >
        <span class="social-share-icon transition-transform group-hover:scale-110" style="color: ${platform.color}" set:html={platform.icon} />
        {showLabels && (
          <span class="social-share-name text-muted-foreground group-hover:text-foreground transition-colors">
            {platform.name}
          </span>
        )}
      </a>
    ))}

    <!-- Copy Link Button -->
    <button
      id="copy-link-btn"
      class="social-share-button group inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-medium transition-all hover:scale-105 bg-card/30 border border-border/20 hover:bg-card/50"
      aria-label="Copy link to clipboard"
    >
      <svg class="h-5 w-5 text-muted-foreground group-hover:text-foreground transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
      </svg>
      {showLabels && (
        <span id="copy-link-text" class="text-muted-foreground group-hover:text-foreground transition-colors">
          Copy Link
        </span>
      )}
    </button>
  </div>
</div>

<script define:vars={{ url }} is:inline>
  const copyBtn = document.getElementById('copy-link-btn')
  const copyText = document.getElementById('copy-link-text')

  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(url)

        // Visual feedback
        if (copyText) {
          const originalText = copyText.textContent
          copyText.textContent = 'Copied!'
          copyText.style.color = '#22c55e'

          setTimeout(() => {
            copyText.textContent = originalText
            copyText.style.color = ''
          }, 2000)
        }

        // Optional: Show toast notification
        const toast = document.createElement('div')
        toast.className = 'fixed bottom-4 right-4 bg-primary text-primary-foreground px-4 py-2 rounded-lg shadow-lg z-50 animate-fade-in'
        toast.textContent = 'Link copied to clipboard!'
        document.body.appendChild(toast)

        setTimeout(() => {
          toast.remove()
        }, 2000)
      } catch (err) {
        console.error('Failed to copy:', err)
      }
    })
  }
</script>

<style>
  .social-share-button {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .social-share-button:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--platform-color, rgba(255, 255, 255, 0.2));
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.3s ease-out;
  }
</style>
