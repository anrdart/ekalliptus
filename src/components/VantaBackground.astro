---
interface Props {
  isDark?: boolean
}

const { isDark = true } = Astro.props
---

<div id="vanta-container" class="fixed inset-0" style="width: 100vw; height: 100vh; z-index: -10">
  <div id="vanta-canvas" class="absolute inset-0"></div>
</div>

<script>
  declare global {
    interface Window {
      VANTA?: {
        NET: (options: Record<string, unknown>) => { destroy: () => void; setOptions: (options: Record<string, unknown>) => void }
      }
      THREE?: unknown
    }
  }

  const container = document.getElementById('vanta-container')
  if (container) {
    const setGradient = () => {
      const isDark = document.documentElement.classList.contains('dark')
      container.style.background = isDark
        ? 'radial-gradient(ellipse 120% 80% at 50% -20%, #1e293b 0%, #0c1222 50%, #020617 100%)'
        : 'radial-gradient(ellipse 120% 80% at 50% -20%, #ffffff 0%, #f1f5f9 50%, #e2e8f0 100%)'
    }
    setGradient()

    const isTouchOnly = window.matchMedia('(pointer: coarse)').matches && window.innerWidth < 1024
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const willLoadVanta = !isTouchOnly && !reducedMotion

    let vantaEffect: { destroy: () => void; setOptions: (options: Record<string, unknown>) => void } | null = null

    const darkConfig = {
      color: 0x38bdf8,
      backgroundColor: 0x0c1222,
      maxDistance: 17.0,
      spacing: 22.0
    }
    const lightConfig = {
      color: 0x2dd4bf,
      backgroundColor: 0xf1f5f9,
      maxDistance: 17.0,
      spacing: 24.0
    }

    const initVanta = () => {
      if (vantaEffect) return
      const el = document.getElementById('vanta-canvas')
      if (!el || !window.VANTA || !window.THREE) return
      const isDark = document.documentElement.classList.contains('dark')
      vantaEffect = window.VANTA.NET({
        el,
        THREE: window.THREE,
        mouseControls: true,
        touchControls: false,
        gyroControls: false,
        minHeight: 200.0,
        minWidth: 200.0,
        scale: 1.0,
        scaleMobile: 1.0,
        ...(isDark ? darkConfig : lightConfig)
      })
    }

    if (willLoadVanta) {
      if (window.VANTA && window.THREE) {
        initVanta()
      } else {
        window.addEventListener('vanta-ready', initVanta, { once: true })
      }
    }

    let themeDebounce: number | undefined
    const observer = new MutationObserver(() => {
      window.clearTimeout(themeDebounce)
      themeDebounce = window.setTimeout(() => {
        setGradient()
        if (vantaEffect) {
          const isDark = document.documentElement.classList.contains('dark')
          vantaEffect.setOptions(isDark ? darkConfig : lightConfig)
        }
      }, 80)
    })
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] })

    document.addEventListener('astro:before-swap', () => {
      observer.disconnect()
      vantaEffect?.destroy()
      vantaEffect = null
    })
  }
</script>
